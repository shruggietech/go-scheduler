<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v5 source for the go-schedule Windows installer (.msi).

  Builds a per-machine installer that:
    * installs goschedd.exe / gosched-gui.exe / gosched.exe to
      "C:\Program Files\go-schedule\",
    * registers goschedd as an auto-start Windows service (started on install,
      stopped + removed on uninstall),
    * adds a Start-Menu shortcut to the windowless GUI,
    * upgrades in place (MajorUpgrade) and uninstalls cleanly. User data under
      C:\ProgramData\goschedule is created by the daemon at runtime and is left
      in place on uninstall.

  Build (CI, on a Windows runner with WiX v5):
    wix build build/windows/goschedule.wxs -arch x64 ^
      -d Version=%VERSION_NUMERIC% -d StageDir=%STAGE% ^
      -o dist\go-schedule_%VERSION%_windows_amd64.msi

  Notes:
    * UpgradeCode MUST stay constant across all releases (it identifies the
      product line for upgrades) — do not regenerate it.
    * Version must be numeric (e.g. 1.2.3); strip any leading "v" before passing.
    * StageDir is the folder holding the three built .exe files.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package
      Name="go-schedule"
      Manufacturer="ShruggieTech"
      Version="$(Version)"
      UpgradeCode="b6f3c2e1-7a4d-4c9e-9b2a-1f6d8e5a0c34"
      Scope="perMachine"
      Compressed="yes">

    <SummaryInformation Description="go-schedule — cross-platform task scheduler" />

    <MajorUpgrade
        AllowSameVersionUpgrades="yes"
        DowngradeErrorMessage="A newer version of go-schedule is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Before installing files, terminate any running daemon (a leftover from a
         prior version or a non-service dev instance) so it can't hold the IPC
         pipe or lock the .exe being replaced. Best-effort: missing process is
         fine. The service's own daemon is stopped by ServiceControl on upgrade;
         this also clears any stray process. -->
    <util:CloseApplication
        Id="CloseStaleDaemon"
        Target="goschedd.exe"
        TerminateProcess="1"
        RebootPrompt="no" />

    <!-- A simple, themed install wizard so the user gets a clear Welcome and a
         "Completed successfully" finish page (instead of a silent progress bar). -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="build/windows/license.rtf" />

    <!-- Install location: C:\Program Files\go-schedule\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="go-schedule" />
    </StandardDirectory>

    <!-- Start-Menu folder for the GUI shortcut. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="go-schedule" />
    </StandardDirectory>

    <Feature Id="Main" Title="go-schedule" Level="1">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentRef Id="AppShortcut" />
    </Feature>

    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <!-- The daemon, hosted as a Windows service. -->
      <Component Id="Goschedd" Guid="*">
        <File Id="goschedd.exe" Source="$(StageDir)\goschedd.exe" KeyPath="yes" />
        <ServiceInstall
            Id="GoscheddService"
            Name="goschedd"
            DisplayName="go-schedule"
            Description="Cross-platform task scheduler daemon"
            Type="ownProcess"
            Start="auto"
            ErrorControl="normal"
            Account="LocalSystem"
            Vital="yes" />
        <!-- Start on install; stop + remove on uninstall. -->
        <ServiceControl
            Id="GoscheddServiceControl"
            Name="goschedd"
            Start="install"
            Stop="both"
            Remove="uninstall"
            Wait="yes" />
      </Component>

      <!-- The desktop GUI (windowless build). -->
      <Component Id="GoschedGui" Guid="*">
        <File Id="gosched_gui.exe" Source="$(StageDir)\gosched-gui.exe" KeyPath="yes" />
      </Component>

      <!-- The CLI. -->
      <Component Id="Gosched" Guid="*">
        <File Id="gosched.exe" Source="$(StageDir)\gosched.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Start-Menu shortcut to the GUI (per-machine; HKLM keypath). -->
    <Component Id="AppShortcut" Directory="AppMenuFolder" Guid="*">
      <Shortcut
          Id="GuiShortcut"
          Name="go-schedule"
          Description="Open the go-schedule desktop app"
          Target="[INSTALLFOLDER]gosched-gui.exe"
          WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue Root="HKLM" Key="Software\ShruggieTech\go-schedule" Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

  </Package>
</Wix>
